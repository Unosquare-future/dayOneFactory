# ------------------------------------------------------------------------
# DayOne Flow Factory — environment variables
# Copy this to `.env.local` and fill in the real values.
# `.env.local` is gitignored; this template is safe to commit.
# ------------------------------------------------------------------------

# --- Supabase (client-side — used by the running app) --------------------
# Find these at Supabase → Project Settings → API
VITE_SUPABASE_URL=https://aassdckairtqibpgvhlj.supabase.co
VITE_SUPABASE_ANON_KEY=

# The storage bucket used for inventory images. Create it in Supabase →
# Storage, mark it "public" so the anon key can read objects.
VITE_SUPABASE_BUCKET=inventory-images

# --- Seed-script only (never loaded into the client bundle) --------------
# Only needed when running `node scripts/seed-inventory-images.mjs`
# Get at Supabase → Project Settings → API → `service_role` key.
# NEVER commit this key. Keep it in .env.local on your machine only.
SUPABASE_SERVICE_ROLE_KEY=

# Unsplash Access Key — create a free developer app at
# https://unsplash.com/developers and copy the "Access Key".
UNSPLASH_ACCESS_KEY=
